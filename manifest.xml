<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  MANIFESTO DO ADD-IN "MEUS TEMPLATES"
  =====================================
  Antes de instalar, substitua todas as ocorrências de:
    https://app-outlook-templates.onrender.com
  pela URL real onde o add-in está hospedado (ex: https://meus-templates.onrender.com)
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="MailApp">

  <!-- ID único do add-in. Não altere após publicar. -->
  <Id>c8a7b6d5-e4f3-12ab-9876-543210fedcba</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>RPZ</ProviderName>
  <DefaultLocale>pt-BR</DefaultLocale>
  <DisplayName DefaultValue="Meus Templates" />
  <Description DefaultValue="Crie, armazene e reutilize templates de email no Outlook" />

  <!-- Ícone exibido na ribbon. Substitua pelas URLs dos seus ícones. -->
  <IconUrl DefaultValue="https://app-outlook-templates.onrender.com/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://app-outlook-templates.onrender.com/assets/icon-64.png" />
  <SupportUrl DefaultValue="https://app-outlook-templates.onrender.com" />

  <AppDomains>
    <AppDomain>https://app-outlook-templates.onrender.com</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1" />
    </Sets>
  </Requirements>

  <!-- Comportamento legado (Outlook 2013/2016 sem VersionOverrides) -->
  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://app-outlook-templates.onrender.com/index.html" />
        <RequestedHeight>220</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
    <Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Edit" />
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <!-- VersionOverrides: botão na ribbon para Outlook moderno -->
  <VersionOverrides
    xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
    xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url" />

          <!-- Botão na ribbon ao compor mensagem -->
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgComposeCmdGroup">
                <Label resid="GroupLabel" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>
                <Control xsi:type="Button" id="msgComposeOpenPaneButton">
                  <Label resid="TaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="TaskpaneButton.Label" />
                    <Description resid="TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>MeusTemplatesPane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

          <!-- Botão na ribbon ao compor resposta/agendamento -->
          <ExtensionPoint xsi:type="AppointmentOrganizerCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="apptComposeCmdGroup">
                <Label resid="GroupLabel" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>
                <Control xsi:type="Button" id="apptComposeOpenPaneButton">
                  <Label resid="TaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="TaskpaneButton.Label" />
                    <Description resid="TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>MeusTemplatesPane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <!-- Substitua pelas URLs dos seus ícones reais -->
        <bt:Image id="Icon.16x16" DefaultValue="https://app-outlook-templates.onrender.com/assets/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://app-outlook-templates.onrender.com/assets/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://app-outlook-templates.onrender.com/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://app-outlook-templates.onrender.com/commands.html" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://app-outlook-templates.onrender.com/index.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Meus Templates" />
        <bt:String id="TaskpaneButton.Label" DefaultValue="Meus Templates" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Abrir painel de templates de email" />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
